# Media Recommender Environment Configuration

# API Keys
TMDB_API_KEY=your_tmdb_api_key_here
TMDB_READ_ACCESS_TOKEN=your_tmdb_read_access_token_here
MANGADEX_API_KEY=your_mangadex_api_key_here
MAL_CLIENT_ID=your_mal_client_id_here
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
HF_TOKEN=your_huggingface_token_here

# Data Paths
DATA_PATH=backend/data/raw/anime_Jan26.parquet
MULTI_MEDIA_DATA_PATH=backend/data/processed/multi_media_v1.parquet

# Vector Database
VECTOR_DB_PROVIDER=qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_PATH=backend/data/qdrant
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=anime_embeddings_v2

# Embedding Model
EMBEDDING_MODEL=google/embeddinggemma-300m
EMBEDDING_DIMENSION=768

# Retry & Timeout
API_MAX_RETRIES=3
API_BACKOFF_FACTOR=2.0
API_TIMEOUT=30
TMDB_TIMEOUT=30
MANGADEX_TIMEOUT=30
MAL_TIMEOUT=30

# Ingestion
INGESTION_BATCH_SIZE=100
CHECKPOINT_DIR=backend/data/checkpoints
PROCESSED_DATA_DIR=backend/data/processed

# Data Quality
MIN_SYNOPSIS_LENGTH=50
MIN_SCORE_THRESHOLD=0.0
REQUIRE_GENRES=false

# LLM Settings
LLM_MODEL=openai:gpt-4o

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
